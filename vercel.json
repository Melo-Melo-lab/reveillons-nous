{
  "buildCommand": "",
  "rewrites": [
    { "source": "/api/:path*",      "destination": "https://reveillons-nous-production.up.railway.app/api/:path*" },
    { "source": "/uploads/:path*",  "destination": "https://reveillons-nous-production.up.railway.app/uploads/:path*" },
    { "source": "/admin/:path*",    "destination": "https://reveillons-nous-production.up.railway.app/admin/:path*" },
    { "source": "/admin",           "destination": "https://reveillons-nous-production.up.railway.app/admin" },
    { "source": "/gate",            "destination": "https://reveillons-nous-production.up.railway.app/gate" },
    { "source": "/evenements",      "destination": "/evenements.html" },
    { "source": "/evenement",       "destination": "/evenement.html" }
  ]
}
